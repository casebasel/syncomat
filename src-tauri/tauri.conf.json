{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Syncomat",
  "version": "0.1.4",
  "identifier": "ch.ca-se.syncomat",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Syncomat",
        "width": 480,
        "height": 720,
        "minWidth": 380,
        "minHeight": 560,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "externalBin": ["binaries/syncthing"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIyQ0YyMkVBQTIyNkE0NTUKUldSVnBDYWk2aUxQc21iRXNkcTRnTlVwZlNvZTU4UFR0UUxEcDRjOFcwL3poKzNRditqcGlNNFIK",
      "endpoints": [
        "https://github.com/casebasel/syncomat/releases/latest/download/latest.json"
      ]
    }
  }
}
