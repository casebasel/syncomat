{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Syncomat",
  "version": "0.2.0",
  "identifier": "ch.ca-se.syncomat",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Syncomat",
        "width": 880,
        "height": 640,
        "minWidth": 720,
        "minHeight": 540,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "externalBin": ["binaries/syncthing"],
    "createUpdaterArtifacts": true,
    "publisher": "Marlon Candeloro",
    "homepage": "https://github.com/casebasel/syncomat",
    "shortDescription": "P2P-Sync ohne Login. Resilio-artig auf Syncthing.",
    "longDescription": "Syncomat ist eine schlanke Desktop-GUI über Syncthing. Pärchen pairen per Einladungs-Code; danach werden alle eigenen Ordner automatisch geteilt. macOS arm64 + Windows x64, ein Window, kein Account, signierte OTA-Updates.",
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./windows-installer/install-hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIyQ0YyMkVBQTIyNkE0NTUKUldSVnBDYWk2aUxQc21iRXNkcTRnTlVwZlNvZTU4UFR0UUxEcDRjOFcwL3poKzNRditqcGlNNFIK",
      "endpoints": [
        "https://github.com/casebasel/syncomat/releases/latest/download/latest.json"
      ]
    }
  }
}
